# =========================================
# CNPJ API environment configuration
# =========================================

# HTTP port used by the API server
PORT=3000

# =========================================
# Database
# =========================================

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/database

# Maximum number of concurrent connections in the PostgreSQL pool
# Increase carefully, especially when multiple services share the same database
DATABASE_POOL_MAX=10

# Maximum time an idle database connection can remain open in the pool
DATABASE_IDLE_TIMEOUT_MS=30000

# Maximum time allowed to establish a new database connection
# This does not control query execution time
DATABASE_CONNECTION_TIMEOUT_MS=5000

# Maximum time the PostgreSQL driver will wait for a query to complete
# Useful for heavy endpoints and cold-cache scenarios
DATABASE_QUERY_TIMEOUT_MS=90000

# Maximum execution time allowed for a SQL statement in PostgreSQL
# Keep this aligned with DATABASE_QUERY_TIMEOUT_MS when possible
DATABASE_STATEMENT_TIMEOUT_MS=90000

# =========================================
# HTTP server
# =========================================

# Maximum time the API will wait before aborting an HTTP request
# Increase this when some endpoints depend on heavy database queries
REQUEST_TIMEOUT_MS=90000

# Maximum time allowed to establish the HTTP connection
# This is not the same as request processing time
CONNECTION_TIMEOUT_MS=5000

# Maximum idle time for keep-alive HTTP connections
KEEP_ALIVE_TIMEOUT_MS=5000