# =========================================
# Configuração de ambiente da CNPJ API
# =========================================

# Porta HTTP utilizada pelo servidor da API
PORT=3000

# =========================================
# Banco de dados
# =========================================

# String de conexão com o PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/database

# Número máximo de conexões simultâneas no pool do PostgreSQL
# Aumente com cautela, especialmente quando múltiplos serviços compartilham o mesmo banco
DATABASE_POOL_MAX=10

# Tempo máximo que uma conexão ociosa pode permanecer aberta no pool
DATABASE_IDLE_TIMEOUT_MS=30000

# Tempo máximo permitido para estabelecer uma nova conexão com o banco
# Isso não controla o tempo de execução das consultas
DATABASE_CONNECTION_TIMEOUT_MS=5000

# Tempo máximo que o driver PostgreSQL aguardará uma consulta terminar
# Útil para endpoints pesados e cenários com cache frio
DATABASE_QUERY_TIMEOUT_MS=90000

# Tempo máximo permitido para a execução de uma instrução SQL no PostgreSQL
# Sempre que possível, mantenha este valor alinhado com DATABASE_QUERY_TIMEOUT_MS
DATABASE_STATEMENT_TIMEOUT_MS=90000

# =========================================
# Servidor HTTP
# =========================================

# Tempo máximo que a API aguardará antes de abortar uma requisição HTTP
# Aumente este valor quando alguns endpoints dependerem de consultas pesadas no banco
REQUEST_TIMEOUT_MS=90000

# Tempo máximo permitido para estabelecer a conexão HTTP
# Isso não é o mesmo que o tempo de processamento da requisição
CONNECTION_TIMEOUT_MS=5000

# Tempo máximo de inatividade para conexões HTTP keep-alive
KEEP_ALIVE_TIMEOUT_MS=5000